{
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=walletdb;Username=postgres;Password=postgres"
  },
  "Redis": {
    "ConnectionString": "redis:6379,password=redis@54321,ssl=false,abortConnect=false"
  },
  "Jwt": {
    "Issuer": "wallet-app",
    "Audience": "wallet-mini",
    "Secret": "0a4d55a8d778e5022fab701977c5d840bbc486d0"
  },
  "Authentication": {
    "Google": {
      "ClientId": "990653409746-9ou0k28hhivb6o822nqscok3u5ttl8to.apps.googleusercontent.com",
      "ClientSecret": "AIzaSyA_t-uUxAQ2O1RO8bkglKVpJr9B89ubRXM"
    }
  },
  "ReverseProxy": {
      "Routes": {
      "auth-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeadersCopy": "true"
          }
        ]
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/wallet/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeadersCopy": "true"
          }
        ]
      },
      "signalr-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/hubs/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeadersCopy": "true"
          }
        ]
      }
    },
    "Clusters": {
      "wallet-cluster": {
        "LoadBalancingPolicy": "LeastRequests",
        "Destinations": {
          "wallet-api-default": {
            "Address": "http://wallet-api:8080"
          }
        }
      },
      "notification-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "notification-api-default": {
            "Address": "http://wallet-notification:8080"
          }
        }
      }
    }
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  }
}